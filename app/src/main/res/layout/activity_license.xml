<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center_horizontal">

        <!-- Logo / 标题 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🌉 网桥隧道 Pro"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#1A73E8"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ClawClaw.tech · ¥499 买断"
            android:textSize="14sp"
            android:textColor="#666666"
            android:layout_marginBottom="24dp" />

        <!-- 试用状态卡片 -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardElevation="2dp"
            app:cardCornerRadius="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/trialStatusText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="试用期剩余: --"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#FF9800" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="24小时免费试用 · 到期后需激活码"
                    android:textSize="12sp"
                    android:textColor="#999999"
                    android:layout_marginTop="4dp" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- 机器码卡片 -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardElevation="1dp"
            app:cardCornerRadius="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/machineIdText"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="机器码: ----"
                        android:textSize="14sp"
                        android:textColor="#333333"
                        android:fontFamily="monospace" />

                    <Button
                        android:id="@+id/btnCopyMachineId"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="复制"
                        android:textSize="12sp"
                        android:minWidth="0dp"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        app:cornerRadius="18dp" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="将机器码发送给客服获取激活码"
                    android:textSize="12sp"
                    android:textColor="#999999"
                    android:layout_marginTop="6dp" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- 激活码输入 -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            app:cardElevation="2dp"
            app:cardCornerRadius="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔑 输入激活码"
                    android:textSize="14sp"
                    android:textColor="#1A73E8"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <EditText
                    android:id="@+id/licenseCodeInput"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:hint="XXXX-XXXX-XXXX-XXXX"
                    android:inputType="textCapCharacters|textVisiblePassword"
                    android:textSize="18sp"
                    android:fontFamily="monospace"
                    android:textAlignment="center"
                    android:maxLength="19"
                    android:background="@android:drawable/editbox_background" />

                <Button
                    android:id="@+id/btnActivate"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="12dp"
                    android:text="激活"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:backgroundTint="#1A73E8"
                    android:enabled="false"
                    app:cornerRadius="24dp" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- 继续试用按钮 -->
        <Button
            android:id="@+id/btnTrial"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="继续试用"
            android:textSize="14sp"
            android:textColor="#666666"
            android:backgroundTint="#E0E0E0"
            app:cornerRadius="24dp" />

        <!-- 购买说明 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="购买渠道: ClawClaw.tech\n代理商: clawclaw.tech/agent\n激活码: 50元/个 (代理商价)"
            android:textSize="12sp"
            android:textColor="#AAAAAA"
            android:textAlignment="center"
            android:lineSpacingExtra="4dp" />

    </LinearLayout>
</ScrollView>
