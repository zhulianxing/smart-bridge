<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- 标题 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🌉 网桥隧道"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#1A73E8"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="选择城市，一键全球上网"
            android:textSize="14sp"
            android:textColor="#666666"
            android:layout_marginBottom="8dp" />

        <!-- 授权状态徽章 -->
        <TextView
            android:id="@+id/trialBadgeText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="12sp"
            android:textColor="#FF9800"
            android:layout_marginBottom="12dp" />

        <!-- 状态卡片 -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardElevation="2dp"
            app:cardCornerRadius="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/statusText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="○ 已停止"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#888888" />

                <TextView
                    android:id="@+id/ipText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="本机 IP: --"
                    android:textSize="13sp"
                    android:textColor="#666666"
                    android:layout_marginTop="6dp" />

                <TextView
                    android:id="@+id/exitIpText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="出口 IP: --"
                    android:textSize="13sp"
                    android:textColor="#666666"
                    android:layout_marginTop="2dp" />

                <TextView
                    android:id="@+id/proxyHint"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textSize="13sp"
                    android:textColor="#1A73E8"
                    android:layout_marginTop="2dp" />

                <ProgressBar
                    android:id="@+id/progressBar"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="4dp"
                    android:layout_marginTop="12dp"
                    android:indeterminate="true"
                    android:visibility="gone" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- 服务器选择 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="选择服务器"
            android:textSize="14sp"
            android:textColor="#1A73E8"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <!-- 服务器城市列表 -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/serverList"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:nestedScrollingEnabled="false" />

        <!-- 按钮 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <Button
                android:id="@+id/btnStart"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:text="🚀 启动"
                android:textSize="16sp"
                android:textStyle="bold"
                android:backgroundTint="#34A853"
                android:layout_marginEnd="8dp"
                app:cornerRadius="28dp" />

            <Button
                android:id="@+id/btnStop"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:text="⏹ 停止"
                android:textSize="16sp"
                android:textStyle="bold"
                android:backgroundTint="#EA4335"
                android:layout_marginStart="8dp"
                app:cornerRadius="28dp"
                android:visibility="gone" />
        </LinearLayout>

        <!-- 使用说明 -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardElevation="1dp"
            app:cardCornerRadius="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📖 其他设备使用"
                    android:textSize="14sp"
                    android:textColor="#1A73E8"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="1. 确保同一 Wi‑Fi 网络"
                    android:textSize="13sp"
                    android:textColor="#444"
                    android:lineSpacingExtra="4dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="2. Wi‑Fi → 高级 → 代理 → 手动"
                    android:textSize="13sp"
                    android:textColor="#444"
                    android:lineSpacingExtra="4dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="3. 填入上方显示的本机 IP + HTTP 端口"
                    android:textSize="13sp"
                    android:textColor="#444"
                    android:lineSpacingExtra="4dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="4. 或用 Postern 设 SOCKS5 全局代理"
                    android:textSize="13sp"
                    android:textColor="#444"
                    android:lineSpacingExtra="4dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</ScrollView>
